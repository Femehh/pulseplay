# Database (get free DB from https://neon.tech)
DATABASE_URL="postgresql://user:password@host/pulseplay?sslmode=require"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=production

# Set this to your Vercel frontend URL after deploying
ALLOWED_ORIGINS="https://pulseplay.vercel.app"

# Set these in Vercel dashboard after deploying game server to Render
NEXT_PUBLIC_SOCKET_URL="https://pulseplay-server.onrender.com"
NEXT_PUBLIC_APP_URL="https://pulseplay.vercel.app"
